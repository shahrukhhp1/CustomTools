@model string?

@{
    var title = string.IsNullOrWhiteSpace(Model) ? "Text similarity" : Model!;
}

<style>
    .similarity-page {
        padding: 16px;
    }

    .similarity-page h1 {
        text-align: center;
        margin: 0 0 12px 0;
    }

    .sim-controls {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin: 0 0 12px 0;
        flex-wrap: wrap;
    }

    .sim-intro {
        margin: 0 0 12px 0;
        color: rgba(0,0,0,0.70);
    }

    .sim-options {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin: 0 0 12px 0;
        padding: 10px 12px;
        border: 1px solid rgba(0,0,0,0.15);
        border-radius: 10px;
    }

    .sim-options label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    .sim-options input[type="number"] {
        width: 90px;
        padding: 4px 6px;
    }

    .sim-inputs {
        display: flex;
        justify-content: space-between;
        gap: 5%;
        align-items: stretch;
    }

    .sim-inputs textarea {
        width: 50%;
        height: 40vh;
        min-height: 200px;
        box-sizing: border-box;
        padding: 12px;
    }

    .sim-result {
        margin-top: 16px;
    }

    .sim-bar {
        height: 16px;
        border-radius: 10px;
        background: rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .sim-bar > div {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #dc3545, #ffc107, #198754);
        transition: width 250ms ease;
    }

    .sim-score {
        margin-top: 8px;
        font-weight: 700;
        font-size: 1.3rem;
    }

    .sim-explain {
        margin-top: 6px;
        color: rgba(0,0,0,0.68);
    }

    .sim-copyRow {
        margin-top: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sim-copyText {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        background: rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.10);
        border-radius: 10px;
        padding: 6px 10px;
    }

    .sim-details {
        margin-top: 10px;
        padding: 10px 12px;
        border: 1px solid rgba(0,0,0,0.15);
        border-radius: 10px;
        white-space: pre-wrap;
        word-break: break-word;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        line-height: 1.35;
    }

    .sim-warn {
        margin-top: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        background: rgba(255, 193, 7, 0.25);
        border: 1px solid rgba(255, 193, 7, 0.45);
    }
</style>

@Html.AntiForgeryToken()

<script>
    function clamp01(x) { return Math.max(0, Math.min(1, x)); }

    function buildExplainText() {
        const opts = [];
        if (document.getElementById("simRemoveDiacritics").checked) opts.push("diacritics removed");
        if (document.getElementById("simIgnoreCase").checked) opts.push("case ignored");
        if (document.getElementById("simStripPunctuation").checked) opts.push("punctuation stripped");
        if (document.getElementById("simCollapseWhitespace").checked) opts.push("extra whitespace ignored");
        if (document.getElementById("simRemoveStopwords").checked) opts.push("stopwords removed");

        const ws = document.getElementById("simWordShingleSize").value || "3";
        const cg = document.getElementById("simCharGramSize").value || "5";

        const norm = opts.length ? opts.join(", ") : "no normalization";
        return "Based on word shingles (w-" + ws + "), character n-grams (c-" + cg + "), and word overlap; normalization: " + norm + ".";
    }

    async function copySimilarityText() {
        const text = document.getElementById("simCopyText")?.textContent ?? "";
        if (!text) return;
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            const btn = document.getElementById("simCopyBtn");
            if (btn) {
                const prev = btn.textContent;
                btn.textContent = "Copied";
                setTimeout(() => { btn.textContent = prev; }, 900);
            }
        }
    }

    function swapSimilaritySides() {
        const a = document.getElementById("simText1");
        const b = document.getElementById("simText2");
        if (!a || !b) return;
        const tmp = a.value;
        a.value = b.value;
        b.value = tmp;
        a.focus();
    }

    function useSimilaritySample() {
        const a = document.getElementById("simText1");
        const b = document.getElementById("simText2");
        if (!a || !b) return;
        a.value = [
            "Release notes (v1)",
            "",
            "We improved the JSON viewer so you can format payloads faster.",
            "It now shows a clear status line and lets you copy the result."
        ].join("\n");
        b.value = [
            "Release notes (v2)",
            "",
            "The JSON viewer was upgraded to pretty-print payloads more quickly.",
            "It shows a clear status message and supports copying the output."
        ].join("\n");
        a.focus();
        window.scrollTo(0, a.getBoundingClientRect().top + window.pageYOffset - 120);
    }

    async function copySimilaritySummary() {
        const pct = document.getElementById("simCopyText")?.textContent ?? "";
        if (!pct) return;
        const text = "Compared two texts: " + pct.replace(/^Similarity:\s*/i, "").trim() + " similar.";
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            const btn = document.getElementById("simCopySummaryBtn");
            if (btn) {
                const prev = btn.textContent;
                btn.textContent = "Copied";
                setTimeout(() => { btn.textContent = prev; }, 900);
            }
        }
    }

    async function compareSimilarity() {
        const text1 = document.getElementById("simText1").value;
        const text2 = document.getElementById("simText2").value;

        const token = document.querySelector("input[name='__RequestVerificationToken']")?.value;
        const form = new URLSearchParams();
        form.set("text1", text1);
        form.set("text2", text2);

        form.set("removeDiacritics", document.getElementById("simRemoveDiacritics").checked ? "true" : "false");
        form.set("ignoreCase", document.getElementById("simIgnoreCase").checked ? "true" : "false");
        form.set("stripPunctuation", document.getElementById("simStripPunctuation").checked ? "true" : "false");
        form.set("collapseWhitespace", document.getElementById("simCollapseWhitespace").checked ? "true" : "false");
        form.set("removeStopwords", document.getElementById("simRemoveStopwords").checked ? "true" : "false");
        form.set("wordShingleSize", document.getElementById("simWordShingleSize").value || "3");
        form.set("charGramSize", document.getElementById("simCharGramSize").value || "5");

        const scoreEl = document.getElementById("simScore");
        const explainEl = document.getElementById("simExplain");
        const detailsEl = document.getElementById("simDetails");
        const warnEl = document.getElementById("simWarn");
        const barFill = document.getElementById("simBarFill");
        const copyTextEl = document.getElementById("simCopyText");

        warnEl.style.display = "none";
        warnEl.innerText = "";
        scoreEl.innerText = "Calculating…";
        explainEl.innerText = "";
        detailsEl.innerText = "";
        copyTextEl.innerText = "";
        barFill.style.width = "0%";

        const resp = await fetch("/Home/Similarity", {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
                "RequestVerificationToken": token || ""
            },
            body: form.toString()
        });

        if (!resp.ok) {
            scoreEl.innerText = "Similarity failed (" + resp.status + ")";
            return;
        }

        const data = await resp.json();
        const combined = clamp01((data.combinedScore || 0));
        const pct = combined * 100;
        const pctText = pct.toFixed(1);
        barFill.style.width = Math.round(pct) + "%";

        scoreEl.innerText = "Similarity: " + pctText + "%";
        explainEl.innerText = buildExplainText();
        copyTextEl.innerText = "Similarity: " + pctText + "%";

        const lines = [];
        lines.push("Combined:        " + ((data.combinedScore || 0) * 100).toFixed(1) + "%");
        lines.push("Cosine (words):  " + ((data.cosineScore || 0) * 100).toFixed(1) + "%");
        lines.push("Jaccard (w-" + (data.wordShingleSize || 3) + "):  " + ((data.wordShingleJaccard || 0) * 100).toFixed(1) + "%");
        lines.push("Jaccard (c-" + (data.charGramSize || 5) + "):  " + ((data.charGramJaccard || 0) * 100).toFixed(1) + "%");
        lines.push("");
        lines.push("Tokens A/B:      " + (data.tokenCountA ?? "?") + " / " + (data.tokenCountB ?? "?"));
        lines.push("Unique A/B:      " + (data.uniqueTokenCountA ?? "?") + " / " + (data.uniqueTokenCountB ?? "?"));
        lines.push("Common tokens:   " + (data.commonTokenCount ?? "?"));
        if (data.notes && Array.isArray(data.notes) && data.notes.length) {
            lines.push("");
            lines.push("Notes:");
            for (const n of data.notes) lines.push("- " + n);
        }
        detailsEl.innerText = lines.join("\n");

        if (data.warnings && Array.isArray(data.warnings) && data.warnings.length) {
            warnEl.style.display = "block";
            warnEl.innerText = data.warnings.join("\n");
        }
    }
</script>

<div class="similarity-page">
    <h1>@title</h1>

    <div class="sim-intro">
        Get a similarity percentage between two texts. Adjust normalization options for more accurate comparison of content vs exact strings.
    </div>

    <div class="sim-controls">
        <button id="simCompareBtn" type="button" class="btn btn-primary" onclick="compareSimilarity()">Similarity score</button>
        <button type="button" class="btn btn-outline-secondary" onclick="swapSimilaritySides()">Swap sides</button>
        <button type="button" class="btn btn-outline-secondary" onclick="useSimilaritySample()">Use sample text</button>
    </div>

    <div class="sim-options">
        <label><input id="simRemoveDiacritics" type="checkbox" checked />Remove diacritics</label>
        <label><input id="simIgnoreCase" type="checkbox" checked />Ignore case</label>
        <label><input id="simStripPunctuation" type="checkbox" checked />Strip punctuation</label>
        <label><input id="simCollapseWhitespace" type="checkbox" checked />Collapse whitespace</label>
        <label><input id="simRemoveStopwords" type="checkbox" />Remove stopwords</label>
        <label>Word shingle <input id="simWordShingleSize" type="number" min="2" max="8" step="1" value="3" /></label>
        <label>Char gram <input id="simCharGramSize" type="number" min="3" max="10" step="1" value="5" /></label>
    </div>

    <div class="sim-inputs">
        <textarea id="simText1" placeholder="Enter text A"></textarea>
        <textarea id="simText2" placeholder="Enter text B"></textarea>
    </div>

    <div class="sim-result">
        <div class="sim-bar"><div id="simBarFill"></div></div>
        <div id="simScore" class="sim-score"></div>
        <div id="simExplain" class="sim-explain"></div>
        <div class="sim-copyRow">
            <button id="simCopyBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="copySimilarityText()">Copy result</button>
            <button id="simCopySummaryBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="copySimilaritySummary()">Copy summary</button>
            <button id="simCopyLinkBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="DailyTools.copyCurrentUrl(this)">Share (copy link)</button>
            <span id="simCopyText" class="sim-copyText"></span>
            <details>
                <summary>What are shingles and char grams?</summary>
                <div class="mt-2 text-muted">
                    <div><strong>Word shingles</strong> are consecutive word sequences (e.g., w-3 = 3-word phrases). They catch copy-with-small-edits.</div>
                    <div class="mt-1"><strong>Char grams</strong> are consecutive character sequences (e.g., c-5 = 5-char chunks). They help detect small formatting/typo changes.</div>
                </div>
            </details>
        </div>
        <div id="simWarn" class="sim-warn" style="display:none;"></div>
        <div id="simDetails" class="sim-details"></div>
    </div>
</div>
