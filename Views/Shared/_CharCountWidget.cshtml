@model string?

@{
    var title = string.IsNullOrWhiteSpace(Model) ? "Character count" : Model!;
}

<style>
    .count-page {
        padding: 16px;
    }

    .count-page h1 {
        text-align: center;
        margin: 0 0 12px 0;
    }

    .count-controls {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin: 0 0 16px 0;
    }

    #countText {
        width: 100%;
        height: 40vh;
        min-height: 200px;
        box-sizing: border-box;
        padding: 12px;
    }

    #countStats {
        margin-top: 12px;
        font-weight: 600;
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

    .statBox {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 8px;
        background: #f1f3f5;
    }
</style>

<script>
    function updateCharCount() {
        const text = document.getElementById("countText")?.value ?? "";
        const chars = text.length;
        const charsNoSpaces = text.replace(/\s/g, "").length;
        const words = (text.trim().match(/\S+/g) || []).length;
        const lines = text.length === 0 ? 0 : text.split(/\r\n|\r|\n/).length;

        document.getElementById("statChars").textContent = String(chars);
        document.getElementById("statCharsNoSpaces").textContent = String(charsNoSpaces);
        document.getElementById("statWords").textContent = String(words);
        document.getElementById("statLines").textContent = String(lines);
    }

    function clearCharCount() {
        const el = document.getElementById("countText");
        if (el) el.value = "";
        updateCharCount();
        document.getElementById("countText")?.focus();
    }
</script>

<div class="count-page">
    <h1>@title</h1>

    <div class="count-controls">
        <button type="button" class="btn btn-secondary" onclick="clearCharCount()">Clear</button>
    </div>

    <textarea id="countText" placeholder="Type or paste text..." oninput="updateCharCount()"></textarea>

    <div id="countStats">
        <span class="statBox">Chars: <span id="statChars">0</span></span>
        <span class="statBox">Chars (no spaces): <span id="statCharsNoSpaces">0</span></span>
        <span class="statBox">Words: <span id="statWords">0</span></span>
        <span class="statBox">Lines: <span id="statLines">0</span></span>
    </div>
</div>

<script>
    // Initialize counts on first render
    updateCharCount();
</script>

