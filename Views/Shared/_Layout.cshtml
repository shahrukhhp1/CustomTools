@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "DailyTools")</title>
    @if (!string.IsNullOrWhiteSpace(ViewData["MetaDescription"] as string))
    {
        <meta name="description" content="@(ViewData["MetaDescription"] as string)" />
    }
    @if (!string.IsNullOrWhiteSpace(ViewData["Robots"] as string))
    {
        <meta name="robots" content="@(ViewData["Robots"] as string)" />
        <meta name="googlebot" content="@(ViewData["Robots"] as string)" />
    }

    @{
        var ogTitle = (ViewData["Title"] as string) ?? "DailyTools";
        var ogDesc = (ViewData["MetaDescription"] as string) ?? "Fast, privacy-friendly text & JSON tools. No sign-up.";
        var ogUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
    }
    <link rel="canonical" href="@ogUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DailyTools" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@ogDesc" />
    <meta property="og:url" content="@ogUrl" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@ogDesc" />

    <script>
        (function () {
            try {
                var stored = localStorage.getItem("dtools-theme");
                var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
                var theme = (stored === "dark" || stored === "light") ? stored : (prefersDark ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            } catch (e) { }
        })();
    </script>

    @{
        var umamiEnabled = Configuration.GetValue<bool>("Umami:Enabled");
        var umamiScriptUrl = (Configuration["Umami:ScriptUrl"] ?? "").Trim();
        var umamiWebsiteId = (Configuration["Umami:WebsiteId"] ?? "").Trim();
        var umamiDomains = (Configuration["Umami:Domains"] ?? "").Trim();
        var shouldLoadUmami = umamiEnabled && !string.IsNullOrWhiteSpace(umamiScriptUrl) && !string.IsNullOrWhiteSpace(umamiWebsiteId);
    }
    @if (shouldLoadUmami)
    {
        if (string.IsNullOrWhiteSpace(umamiDomains))
        {
            <script defer src="@umamiScriptUrl" data-website-id="@umamiWebsiteId"></script>
        }
        else
        {
            <script defer src="@umamiScriptUrl" data-website-id="@umamiWebsiteId" data-domains="@umamiDomains"></script>
        }
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CustomWebTools.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Daily Tools <small class="text-muted">fast text &amp; JSON utilities</small>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- Mobile: show tool links directly in the collapsed menu -->
                        <li class="nav-item d-md-none">
                            <a class="nav-link text-dark" href="/text-compare">Text compare</a>
                        </li>
                        <li class="nav-item d-md-none">
                            <a class="nav-link text-dark" href="/similarity-score">Similarity score</a>
                        </li>
                        <li class="nav-item d-md-none">
                            <a class="nav-link text-dark" href="/json-viewer">JSON viewer</a>
                        </li>
                        <li class="nav-item d-md-none">
                            <a class="nav-link text-dark" href="/character-count">Character count</a>
                        </li>
                        <li class="nav-item d-md-none">
                            <a class="nav-link text-dark" href="/word-number-converter">Word ↔ Number</a>
                        </li>

                        <!-- Desktop: show tools directly in the nav -->
                        <li class="nav-item d-none d-md-block">
                            <a class="nav-link text-dark" href="/text-compare">Text compare</a>
                        </li>
                        <li class="nav-item d-none d-md-block">
                            <a class="nav-link text-dark" href="/similarity-score">Similarity</a>
                        </li>
                        <li class="nav-item d-none d-md-block">
                            <a class="nav-link text-dark" href="/json-viewer">JSON viewer</a>
                        </li>
                        <li class="nav-item d-none d-md-block">
                            <a class="nav-link text-dark" href="/character-count">Char count</a>
                        </li>
                        <li class="nav-item d-none d-md-block">
                            <a class="nav-link text-dark" href="/word-number-converter">Word ↔ Number</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <button id="themeToggle" type="button" class="btn btn-outline-secondary btn-sm" onclick="DailyTools.toggleTheme(this)">
                            Theme
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted mt-4">
        <div class="container py-4">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-7">
                    <div class="fw-semibold text-dark">DailyTools</div>
                    <div class="mt-1" style="max-width: 78ch;">
                        DailyTools is built by a developer for developers and writers who need fast, no-signup utilities.
                        Some tools process your pasted text on the server to generate results. We don’t intentionally store your pasted content after processing.
                    </div>
                    <div class="mt-2 small">
                        Built and maintained by <span class="text-dark">Shahrukh A.</span>
                    </div>
                </div>
                <div class="col-12 col-md-5">
                    <div class="fw-semibold text-dark">Links</div>
                    <div class="mt-1 d-flex flex-wrap gap-3">
                        <a class="text-muted" asp-controller="Home" asp-action="About">About</a>
                        <a class="text-muted" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        <a class="text-muted" href="/changelog">Changelog</a>
                        <a class="text-muted" asp-controller="Home" asp-action="Contact">Contact</a>
                    </div>
                </div>
            </div>
            <div class="mt-3 small">
                &copy; 2026 - DailyTools
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
