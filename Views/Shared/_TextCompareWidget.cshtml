@model string?

@{
    var title = string.IsNullOrWhiteSpace(Model) ? "String or text comparison" : Model!;
}

<style>
    .compare-page {
        padding: 16px;
    }

    .compare-page h1 {
        text-align: center;
        margin: 0 0 12px 0;
    }

    .controls {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
        margin: 0 0 16px 0;
    }

    .inputs {
        display: flex;
        justify-content: space-between;
        gap: 5%;
        align-items: stretch;
    }

    .inputCol {
        width: 50%;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .inputLabel {
        font-weight: 700;
        color: rgba(0,0,0,0.75);
    }

    .inputs textarea {
        width: 100%;
        height: 40vh;
        min-height: 200px;
        box-sizing: border-box;
        padding: 12px;
    }

    #result {
        margin-top: 16px;
        word-break: break-word;
        white-space: pre-wrap;
    }

    #matchStatus {
        margin-top: 8px;
        font-weight: 600;
    }

    .compareStats {
        margin-top: 10px;
        padding: 8px 10px;
        border-radius: 10px;
        background: rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.08);
        font-weight: 700;
        display: inline-block;
    }

    .compareSummaryRow {
        margin-top: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .compareSummaryText {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        background: rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.10);
        border-radius: 10px;
        padding: 6px 10px;
    }

    .allMatched {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 8px;
        background-color: #198754;
        color: #fff;
    }

    .redback {
        background-color: red;
        color: white;
        display: inline-block;
    }

    .greenback {
        background-color: green;
        color: white;
        display: inline-block;
    }
</style>

@Html.AntiForgeryToken()

<script>
    function animateScrollTo(targetY, durationMs) {
        const prefersReducedMotion =
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (prefersReducedMotion) {
            window.scrollTo(0, targetY);
            return;
        }

        const startY = window.pageYOffset;
        const delta = targetY - startY;
        const start = performance.now();

        function easeInOutCubic(t) {
            return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }

        function step(now) {
            const t = Math.min(1, (now - start) / durationMs);
            const eased = easeInOutCubic(t);
            window.scrollTo(0, Math.round(startY + delta * eased));
            if (t < 1) requestAnimationFrame(step);
        }

        requestAnimationFrame(step);
    }

    async function compareTexts() {
        const text1 = document.getElementById("text1").value;
        const text2 = document.getElementById("text2").value;
        const resultArea = $("#result");
        const matchStatus = $("#matchStatus");
        const summaryText = document.getElementById("compareSummaryText");
        const copyBtn = document.getElementById("compareCopyBtn");
        matchStatus.empty();
        resultArea.html("Comparing...");
        if (summaryText) summaryText.textContent = "";
        if (copyBtn) copyBtn.disabled = true;

        const token = document.querySelector("input[name='__RequestVerificationToken']")?.value;
        const form = new URLSearchParams();
        form.set("text1", text1);
        form.set("text2", text2);

        const resp = await fetch("/Home/Compare", {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
                "RequestVerificationToken": token || ""
            },
            body: form.toString()
        });

        if (!resp.ok) {
            resultArea.text("Compare failed (" + resp.status + ")");
            return;
        }

        const html = await resp.text();
        resultArea.html(html);

        // Build a short, copyable summary from the rendered stats.
        try {
            const statsEl = resultArea[0]?.querySelector?.(".compareStats");
            const statsText = statsEl?.textContent ?? "";
            const changed = (statsText.match(/Changed\s+lines:\s*(\d+)/i) || [])[1];
            const sim = (statsText.match(/Similarity.*?:\s*(\d+)\s*%/i) || [])[1];
            if (changed && sim) {
                const s = `Compared two texts: ${sim}% similar, ${changed} changed lines.`;
                if (summaryText) summaryText.textContent = s;
                if (copyBtn) copyBtn.disabled = false;
            } else if (statsText) {
                const s = `Compared two texts: ${statsText.replace(/\s+/g, " ").trim()}`;
                if (summaryText) summaryText.textContent = s;
                if (copyBtn) copyBtn.disabled = false;
            }
        } catch { }

        const firstRed = resultArea[0]?.querySelector?.(".redback");
        if (firstRed) {
            const y =
                firstRed.getBoundingClientRect().top +
                window.pageYOffset -
                Math.floor(window.innerHeight / 2);

            animateScrollTo(Math.max(0, y), 650);

            // brief pulse so it's easy to spot
            if (firstRed.animate) {
                firstRed.animate(
                    [
                        { boxShadow: "0 0 0 0 rgba(255,0,0,0.0)", outline: "0px solid rgba(255,0,0,0.0)", transform: "scale(1)" },
                        { boxShadow: "0 0 0 14px rgba(255,0,0,0.25)", outline: "10px solid rgba(255,0,0,0.9)", transform: "scale(1.35)" },
                        { boxShadow: "0 0 0 0 rgba(255,0,0,0.0)", outline: "0px solid rgba(255,0,0,0.0)", transform: "scale(1)" }
                    ],
                    { duration: 1100, iterations: 2, easing: "ease-in-out" }
                );
            }
        } else {
            matchStatus.html("<span class='allMatched'>All matched</span>");
        }
    }

    function swapCompareSides() {
        const a = document.getElementById("text1");
        const b = document.getElementById("text2");
        if (!a || !b) return;
        const tmp = a.value;
        a.value = b.value;
        b.value = tmp;
        a.focus();
    }

    function useCompareSample() {
        const a = document.getElementById("text1");
        const b = document.getElementById("text2");
        if (!a || !b) return;
        a.value = [
            "Spec v1",
            "",
            "Endpoint: POST /api/users",
            "Response:",
            "{",
            "  \"status\": \"ok\",",
            "  \"user\": { \"id\": 123, \"role\": \"admin\" },",
            "  \"features\": [\"search\", \"export\"],",
            "  \"limits\": { \"requestsPerMinute\": 60 }",
            "}"
        ].join("\n");
        b.value = [
            "Spec v2",
            "",
            "Endpoint: POST /api/users",
            "Response:",
            "{",
            "  \"status\": \"ok\",",
            "  \"user\": { \"id\": 123, \"role\": \"editor\" },",
            "  \"features\": [\"search\", \"export\", \"audit\"],",
            "  \"limits\": { \"requestsPerMinute\": 120 }",
            "}"
        ].join("\n");
        a.focus();
        window.scrollTo(0, a.getBoundingClientRect().top + window.pageYOffset - 120);
    }

    async function copyCompareSummary() {
        const text = document.getElementById("compareSummaryText")?.textContent ?? "";
        if (!text) return;
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            const btn = document.getElementById("compareCopyBtn");
            if (btn) {
                const prev = btn.textContent;
                btn.textContent = "Copied";
                setTimeout(() => { btn.textContent = prev; }, 900);
            }
        }
    }

</script>

<div class="compare-page">
    <h1>@title</h1>

    <div class="controls">
        <button id="compare" type="button" class="btn btn-primary" onclick="compareTexts()">Compare</button>
        <button type="button" class="btn btn-outline-secondary" onclick="swapCompareSides()">Swap sides</button>
        <button type="button" class="btn btn-outline-secondary" onclick="useCompareSample()">Use sample text</button>
    </div>

    <div class="inputs">
        <div class="inputCol">
            <div class="inputLabel">Version A</div>
            <textarea id="text1" placeholder="Example A&#10;{&#10;  &quot;status&quot;: &quot;ok&quot;,&#10;  &quot;user&quot;: { &quot;id&quot;: 123, &quot;role&quot;: &quot;admin&quot; }&#10;}"></textarea>
        </div>
        <div class="inputCol">
            <div class="inputLabel">Version B</div>
            <textarea id="text2" placeholder="Example B&#10;{&#10;  &quot;status&quot;: &quot;ok&quot;,&#10;  &quot;user&quot;: { &quot;id&quot;: 123, &quot;role&quot;: &quot;editor&quot; }&#10;}"></textarea>
        </div>
    </div>

    <div id="matchStatus"></div>
    <div class="compareSummaryRow">
        <button id="compareCopyBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="copyCompareSummary()" disabled>Copy result</button>
        <button id="compareCopyLinkBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="DailyTools.copyCurrentUrl(this)">Share (copy link)</button>
        <span id="compareSummaryText" class="compareSummaryText"></span>
    </div>
    <div id="result"></div>

  
</div>

