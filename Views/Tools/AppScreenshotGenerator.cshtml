@{
    // Titles + meta are set in ToolsController
}

<style>
    .asg-wrap { display: grid; grid-template-columns: 1fr; gap: 14px; }
    @@media (min-width: 992px) { .asg-wrap { grid-template-columns: 420px 1fr; align-items: start; } }
    .asg-card { border: 1px solid rgba(0,0,0,0.08); border-radius: 16px; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.04); padding: 14px 16px; }
    html[data-theme="dark"] .asg-card { background: var(--dt-surface); border-color: var(--dt-border); }
    .asg-title { font-weight: 900; letter-spacing: -0.01em; margin: 0 0 8px 0; font-size: 1.05rem; }
    .asg-help { color: rgba(0,0,0,0.68); font-size: 0.95rem; margin: 0 0 12px 0; }
    html[data-theme="dark"] .asg-help { color: var(--dt-muted); }
    .asg-label { font-weight: 800; color: rgba(0,0,0,0.72); margin-bottom: 6px; }
    html[data-theme="dark"] .asg-label { color: var(--dt-muted); }
    .asg-row { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 10px; }
    .asg-row.two { grid-template-columns: 1fr 1fr; }
    .asg-thumbRow { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px; }
    .asg-thumb { width: 72px; height: 72px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.10); background: rgba(0,0,0,0.02); overflow: hidden; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    html[data-theme="dark"] .asg-thumb { border-color: var(--dt-border); background: rgba(255,255,255,0.04); }
    .asg-thumb.active { outline: 3px solid rgba(13,110,253,0.45); border-color: rgba(13,110,253,0.40); }
    .asg-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .asg-previewCanvasWrap { display: flex; justify-content: center; align-items: center; padding: 10px; border-radius: 14px; border: 1px solid rgba(0,0,0,0.10); background: rgba(0,0,0,0.02); overflow: auto; }
    html[data-theme="dark"] .asg-previewCanvasWrap { border-color: var(--dt-border); background: rgba(255,255,255,0.03); }
    #asgPreview { max-width: 100%; height: auto; border-radius: 12px; background: transparent; }
    .asg-note { margin-top: 10px; color: rgba(0,0,0,0.62); font-size: 0.92rem; }
    html[data-theme="dark"] .asg-note { color: var(--dt-muted); }

    .asg-section {
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 14px;
        padding: 10px 12px;
        margin-bottom: 10px;
        background: rgba(0,0,0,0.01);
    }

    html[data-theme="dark"] .asg-section {
        border-color: var(--dt-border);
        background: rgba(255,255,255,0.02);
    }

    .asg-section > summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        font-weight: 900;
        letter-spacing: -0.01em;
        padding: 2px 0;
    }

    .asg-section > summary::-webkit-details-marker { display: none; }

    .asg-section > summary .asg-section__hint {
        font-weight: 700;
        font-size: 0.85rem;
        color: rgba(0,0,0,0.55);
    }

    html[data-theme="dark"] .asg-section > summary .asg-section__hint { color: var(--dt-muted); }

    .asg-section > summary::after {
        content: "▾";
        color: rgba(0,0,0,0.55);
        font-weight: 900;
        transition: transform 140ms ease, color 140ms ease;
        transform: rotate(0deg);
        flex: 0 0 auto;
    }

    html[data-theme="dark"] .asg-section > summary::after { color: var(--dt-muted); }

    .asg-section[open] > summary::after {
        transform: rotate(180deg);
        color: rgba(0,0,0,0.68);
    }

    html[data-theme="dark"] .asg-section[open] > summary::after { color: rgba(255,255,255,0.70); }
</style>

<div class="mx-auto" style="max-width: 1200px;">
    <h1 class="mb-2">App screenshot generator (iOS &amp; Android)</h1>
    <p class="text-muted mb-3">
        Generate store-style screenshots in your browser. Add background + text and export low/high-resolution PNGs.
        <strong>No sign in required.</strong>
    </p>

    <div class="asg-wrap">
        <div class="asg-card">
            <details class="asg-section">
                <summary>
                    <span>Main</span>
                    <span class="asg-section__hint">frame, size, position</span>
                </summary>
                <div class="mt-2">
                    <div class="asg-row">
                        <div>
                            <div class="asg-label">Platform</div>
                            <select id="asgPlatform" class="form-select">
                                <option value="ios">iOS (App Store)</option>
                                <option value="android" selected>Android (Google Play)</option>
                            </select>
                        </div>
                    </div>

                    <div class="asg-row" id="asgPlayTypeRow">
                        <div>
                            <div class="asg-label">Google Play listing type</div>
                            <select id="asgPlayType" class="form-select">
                                <option value="app" selected>App (needs 4+ screenshots)</option>
                                <option value="game">Game (needs 3+ screenshots)</option>
                            </select>
                            <div class="text-muted small mt-1">
                                Google Play ratios: portrait 9:16 (min 1080×1920), landscape 16:9 (min 1920×1080).
                            </div>
                        </div>
                    </div>

                    <div class="asg-row">
                        <div>
                            <div class="asg-label">Output preset</div>
                            <select id="asgPreset" class="form-select">
                                <!-- Options are populated by JS based on platform -->
                            </select>
                        </div>
                    </div>

                    <div class="asg-row two" id="asgCustomSizeRow">
                        <div>
                            <div class="asg-label">Width</div>
                            <input id="asgW" type="number" class="form-control" min="320" max="4000" step="1" value="1290" />
                        </div>
                        <div>
                            <div class="asg-label">Height</div>
                            <input id="asgH" type="number" class="form-control" min="320" max="6000" step="1" value="2796" />
                        </div>
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Image fit</div>
                            <select id="asgFit" class="form-select">
                                <option value="contain" selected>Contain (no crop)</option>
                                <option value="cover">Cover (crop + pan)</option>
                            </select>
                        </div>
                        <div>
                            <div class="asg-label">Position presets</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <button id="asgPosCenter" type="button" class="btn btn-outline-secondary btn-sm">Center</button>
                                <button id="asgPosTop" type="button" class="btn btn-outline-secondary btn-sm">Top</button>
                                <button id="asgPosBottom" type="button" class="btn btn-outline-secondary btn-sm">Bottom</button>
                                <button id="asgPosLeft" type="button" class="btn btn-outline-secondary btn-sm">Left</button>
                                <button id="asgPosRight" type="button" class="btn btn-outline-secondary btn-sm">Right</button>
                            </div>
                        </div>
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Position X</div>
                            <input id="asgOffsetX" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                            <div class="text-muted small">Tip: drag the preview to move diagonally.</div>
                        </div>
                        <div>
                            <div class="asg-label">Position Y</div>
                            <input id="asgOffsetY" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                            <div class="text-muted small">(-200 = up, +200 = down)</div>
                        </div>
                    </div>
                </div>
            </details>

            <details class="asg-section">
                <summary>
                    <span>Sizing</span>
                    <span class="asg-section__hint">frame, size, shadow</span>
                </summary>
                <div class="mt-2">
                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Frame</div>
                            <select id="asgFrame" class="form-select">
                                <!-- Options are populated by JS based on platform -->
                            </select>
                        </div>
                        <div>
                            <div class="asg-label">Device rotation</div>
                            <input id="asgRotation" type="range" class="form-range" min="-90" max="90" step="1" value="0" />
                            <div class="text-muted small">Degrees (negative = left tilt)</div>
                        </div>
                    </div>

                    <div class="asg-row">
                        <div>
                            <div class="asg-label">Device / screenshot size</div>
                            <input id="asgDeviceScale" type="range" class="form-range" min="60" max="170" step="1" value="100" />
                            <div class="text-muted small">Scales the phone + screenshot together (or zooms screenshot when frame = None)</div>
                        </div>
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Corner radius</div>
                            <input id="asgRadius" type="range" class="form-range" min="0" max="90" step="1" value="34" />
                        </div>
                        <div>
                            <div class="asg-label">Device shadow (on background)</div>
                            <input id="asgShadow" type="range" class="form-range" min="0" max="70" step="1" value="26" />
                        </div>
                    </div>
                </div>
            </details>

            <details class="asg-section">
                <summary>
                    <span>Text</span>
                    <span class="asg-section__hint">title, font, size</span>
                </summary>
                <div class="mt-2">
                    <div class="asg-row">
                        <div>
                            <div class="asg-label">Font (applies to both)</div>
                            <select id="asgFont" class="form-select">
                                <option value="system" selected>System (default)</option>
                                <option value="modern">Modern (SF/Segoe/Roboto)</option>
                                <option value="clean">Clean (Helvetica/Arial)</option>
                                <option value="humanist">Humanist (Segoe UI / Calibri)</option>
                                <option value="rounded">Rounded</option>
                                <option value="condensed">Condensed</option>
                                <option value="slab">Slab serif</option>
                                <option value="serif">Serif</option>
                                <option value="hand">Handwriting</option>
                                <option value="mono">Mono</option>
                            </select>
                            <div class="text-muted small mt-1">Drag: Shift = move Title, Alt+Shift = move Subtitle</div>
                        </div>
                    </div>

                    <div class="asg-row">
                        <div class="asg-label">Title</div>
                        <input id="asgTitle" type="text" class="form-control" placeholder="Example: Track habits effortlessly" />
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Title color</div>
                            <input id="asgTitleColor" type="color" class="form-control form-control-color" value="#ffffff" />
                        </div>
                        <div>
                            <div class="asg-label">Title size</div>
                            <input id="asgTitleScale" type="range" class="form-range" min="60" max="200" step="1" value="100" />
                        </div>
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Title position X</div>
                            <input id="asgTitleOffsetX" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                        </div>
                        <div>
                            <div class="asg-label">Title position Y</div>
                            <input id="asgTitleOffsetY" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                        </div>
                    </div>

                    <div class="asg-row">
                        <div class="d-flex gap-2 flex-wrap">
                            <button id="asgTitleCenter" type="button" class="btn btn-outline-secondary btn-sm">Center title</button>
                        </div>
                    </div>

                    <hr class="my-2" />

                    <div class="asg-row">
                        <div class="asg-label">Subtitle</div>
                        <input id="asgSubtitle" type="text" class="form-control" placeholder="Example: Daily streaks • Reminders • Insights" />
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Subtitle color</div>
                            <input id="asgSubtitleColor" type="color" class="form-control form-control-color" value="#e6f0ff" />
                        </div>
                        <div>
                            <div class="asg-label">Subtitle size</div>
                            <input id="asgSubtitleScale" type="range" class="form-range" min="60" max="200" step="1" value="100" />
                        </div>
                    </div>

                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Subtitle position X</div>
                            <input id="asgSubtitleOffsetX" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                        </div>
                        <div>
                            <div class="asg-label">Subtitle position Y</div>
                            <input id="asgSubtitleOffsetY" type="range" class="form-range" min="-200" max="200" step="1" value="0" />
                        </div>
                    </div>

                    <div class="asg-row">
                        <div class="d-flex gap-2 flex-wrap">
                            <button id="asgSubtitleCenter" type="button" class="btn btn-outline-secondary btn-sm">Center subtitle</button>
                        </div>
                    </div>
                </div>
            </details>

            <details class="asg-section">
                <summary>
                    <span>Background</span>
                    <span class="asg-section__hint">solid / gradient</span>
                </summary>
                <div class="mt-2">
                    <div class="asg-row two">
                        <div>
                            <div class="asg-label">Mode</div>
                            <select id="asgBgMode" class="form-select">
                                <option value="gradient" selected>Gradient</option>
                                <option value="solid">Single color</option>
                            </select>
                        </div>
                        <div>
                            <div class="asg-label">Gradient direction</div>
                            <select id="asgBgDir" class="form-select">
                                <option value="tlbr" selected>Top-left → Bottom-right</option>
                                <option value="trbl">Top-right → Bottom-left</option>
                                <option value="tb">Top → Bottom</option>
                                <option value="lr">Left → Right</option>
                                <option value="radial">Radial</option>
                            </select>
                        </div>
                    </div>

                    <div class="asg-row" id="asgBgSolidRow" style="display:none;">
                        <div>
                            <div class="asg-label">Background color</div>
                            <input id="asgBgSolid" type="color" class="form-control form-control-color" value="#0d6efd" />
                        </div>
                    </div>

                    <div class="asg-row two" id="asgBgGradientRow">
                        <div>
                            <div class="asg-label">Background A</div>
                            <input id="asgBgA" type="color" class="form-control form-control-color" value="#0d6efd" />
                        </div>
                        <div>
                            <div class="asg-label">Background B</div>
                            <input id="asgBgB" type="color" class="form-control form-control-color" value="#198754" />
                        </div>
                    </div>
                </div>
            </details>

            <div class="asg-note">
                Exports are client-side. High-res is generated by rendering at 2× scale.
            </div>
        </div>

        <div class="asg-card">
            <div class="mb-3">
                <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-1">
                    <div>
                        <div class="asg-title mb-0">Screenshots</div>
                        <div class="text-muted">Upload, then click a thumbnail to select.</div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button id="asgCopyProjectJson" type="button" class="btn btn-outline-secondary btn-sm" disabled>Copy project JSON</button>
                        <button id="asgApplyAll" type="button" class="btn btn-outline-primary btn-sm" disabled>Apply settings to all</button>
                    </div>
                </div>

                <input id="asgFiles" type="file" accept="image/*" multiple class="form-control" />
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <button id="asgUseSample" type="button" class="btn btn-outline-secondary btn-sm">Use sample</button>
                    <button id="asgClear" type="button" class="btn btn-outline-secondary btn-sm">Clear</button>
                </div>

                <div class="asg-thumbRow" id="asgThumbRow"></div>
                <div class="asg-note">Each screenshot keeps its own text + settings. Use “Apply settings to all” to copy the current screen’s setup to the others.</div>
            </div>

            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                <div>
                    <div class="asg-title mb-0">Preview</div>
                    <div class="text-muted">Download low/high resolution PNG.</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button id="asgDownloadLow" type="button" class="btn btn-outline-secondary btn-sm" disabled>Download (low)</button>
                    <button id="asgDownloadHigh" type="button" class="btn btn-primary btn-sm" disabled>Download (high)</button>
                </div>
            </div>

            <div class="asg-previewCanvasWrap">
                <canvas id="asgPreview" width="600" height="1200"></canvas>
            </div>
            <div class="asg-note" id="asgStatus"></div>
            <div class="asg-note" id="asgPlayHints"></div>
        </div>
    </div>

    <hr class="my-4" />

    <h2 class="h5">FAQ</h2>
    <details>
        <summary class="fw-semibold">Does this upload my screenshots?</summary>
        <div class="text-muted mt-2">No — rendering is done in your browser using Canvas.</div>
    </details>
</div>

<script>
    (function () {
        "use strict";

        var elFiles = document.getElementById("asgFiles");
        var elThumbRow = document.getElementById("asgThumbRow");
        var elUseSample = document.getElementById("asgUseSample");
        var elClear = document.getElementById("asgClear");
        var elApplyAll = document.getElementById("asgApplyAll");

        var elPlatform = document.getElementById("asgPlatform");
        var elPlayTypeRow = document.getElementById("asgPlayTypeRow");
        var elPreset = document.getElementById("asgPreset");
        var elPlayType = document.getElementById("asgPlayType");
        var elCustomSizeRow = document.getElementById("asgCustomSizeRow");
        var elW = document.getElementById("asgW");
        var elH = document.getElementById("asgH");
        var elTitle = document.getElementById("asgTitle");
        var elSubtitle = document.getElementById("asgSubtitle");
        var elFont = document.getElementById("asgFont");
        var elTitleColor = document.getElementById("asgTitleColor");
        var elSubtitleColor = document.getElementById("asgSubtitleColor");
        var elTitleScale = document.getElementById("asgTitleScale");
        var elSubtitleScale = document.getElementById("asgSubtitleScale");
        var elTitleOffsetX = document.getElementById("asgTitleOffsetX");
        var elTitleOffsetY = document.getElementById("asgTitleOffsetY");
        var elSubtitleOffsetX = document.getElementById("asgSubtitleOffsetX");
        var elSubtitleOffsetY = document.getElementById("asgSubtitleOffsetY");
        var elTitleCenter = document.getElementById("asgTitleCenter");
        var elSubtitleCenter = document.getElementById("asgSubtitleCenter");
        var elBgMode = document.getElementById("asgBgMode");
        var elBgDir = document.getElementById("asgBgDir");
        var elBgSolidRow = document.getElementById("asgBgSolidRow");
        var elBgGradientRow = document.getElementById("asgBgGradientRow");
        var elBgSolid = document.getElementById("asgBgSolid");
        var elBgA = document.getElementById("asgBgA");
        var elBgB = document.getElementById("asgBgB");
        var elRadius = document.getElementById("asgRadius");
        var elShadow = document.getElementById("asgShadow");
        var elFrame = document.getElementById("asgFrame");
        var elRotation = document.getElementById("asgRotation");
        var el3dEnabled = document.getElementById("asg3dEnabled");
        var elTiltX = document.getElementById("asgTiltX");
        var elTiltY = document.getElementById("asgTiltY");
        var elDepth = document.getElementById("asgDepth");
        var elFit = document.getElementById("asgFit");
        var elDeviceScale = document.getElementById("asgDeviceScale");
        var elOffsetX = document.getElementById("asgOffsetX");
        var elOffsetY = document.getElementById("asgOffsetY");
        var elPosCenter = document.getElementById("asgPosCenter");
        var elPosTop = document.getElementById("asgPosTop");
        var elPosBottom = document.getElementById("asgPosBottom");
        var elPosLeft = document.getElementById("asgPosLeft");
        var elPosRight = document.getElementById("asgPosRight");

        var elDownloadLow = document.getElementById("asgDownloadLow");
        var elDownloadHigh = document.getElementById("asgDownloadHigh");
        var elStatus = document.getElementById("asgStatus");
        var elPlayHints = document.getElementById("asgPlayHints");
        var elCopyProjectJson = document.getElementById("asgCopyProjectJson");

        var previewCanvas = document.getElementById("asgPreview");
        var previewCtx = previewCanvas.getContext("2d");

        var lastPreviewScale = 1;
        var project = {
            version: 1,
            platform: "android",
            playType: "app",
            screens: []
        };
        // Expose for debugging / future "save project" work.
        window.__asgProject = project;
        window.__asgProjectJson = "";

        var activeIndex = -1;
        var rafId = 0;
        var PAN_MAX = 200; // percent of screen dimension
        var TEXT_PAN_MAX = 200; // percent of output dimension
        var SCALE_MIN = 60;
        var SCALE_MAX = 170;
        var TEXT_SCALE_MAX = 200;

        function clamp(n, min, max) { return Math.max(min, Math.min(max, n)); }

        function roundedRectPath(ctx, x, y, w, h, r) {
            var rr = Math.max(0, Math.min(r, Math.min(w, h) / 2));
            ctx.beginPath();
            ctx.moveTo(x + rr, y);
            ctx.arcTo(x + w, y, x + w, y + h, rr);
            ctx.arcTo(x + w, y + h, x, y + h, rr);
            ctx.arcTo(x, y + h, x, y, rr);
            ctx.arcTo(x, y, x + w, y, rr);
            ctx.closePath();
        }

        function readNumber(el, fallback) {
            var n = parseInt(el.value, 10);
            return Number.isFinite(n) ? n : fallback;
        }

        function readFloat(el, fallback) {
            var n = parseFloat(el.value);
            return Number.isFinite(n) ? n : fallback;
        }

        function getFontStack(key) {
            if (key === "modern") return 'system-ui, -apple-system, "SF Pro Display", "SF Pro Text", "Segoe UI", Roboto, Arial, sans-serif';
            if (key === "clean") return '"Helvetica Neue", Helvetica, Arial, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif';
            if (key === "humanist") return '"Segoe UI", Calibri, "Trebuchet MS", system-ui, -apple-system, Roboto, Arial, sans-serif';
            if (key === "rounded") return 'ui-rounded, "SF Pro Rounded", "Segoe UI Rounded", system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif';
            if (key === "condensed") return '"Aptos Narrow", "Arial Narrow", "HelveticaNeue-CondensedBold", "Helvetica Neue Condensed", "Roboto Condensed", "Segoe UI", Arial, sans-serif';
            if (key === "slab") return '"Rockwell", "Roboto Slab", "Segoe UI", Georgia, serif';
            if (key === "serif") return 'ui-serif, Georgia, "Times New Roman", Times, serif';
            if (key === "hand") return '"Bradley Hand", "Segoe Script", "Comic Sans MS", "Apple Chancery", cursive';
            if (key === "mono") return 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace';
            return 'system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif';
        }

        function updateBackgroundVisibility() {
            var mode = elBgMode ? (elBgMode.value || "gradient") : "gradient";
            if (elBgSolidRow) elBgSolidRow.style.display = (mode === "solid") ? "" : "none";
            if (elBgGradientRow) elBgGradientRow.style.display = (mode === "gradient") ? "" : "none";
            if (elBgDir) elBgDir.disabled = (mode !== "gradient");
        }

        function update3dControls() {
            if (!el3dEnabled) return;
            var on = !!el3dEnabled.checked;
            if (elTiltX) elTiltX.disabled = !on;
            if (elTiltY) elTiltY.disabled = !on;
            if (elDepth) elDepth.disabled = !on;
        }

        function getBasePad(outW, outH) {
