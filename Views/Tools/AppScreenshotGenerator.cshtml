            if (elTitleOffsetY) elTitleOffsetY.value = String((typeof opts.titleOffsetY === "number") ? opts.titleOffsetY : 0);
            if (elSubtitleOffsetX) elSubtitleOffsetX.value = String((typeof opts.subtitleOffsetX === "number") ? opts.subtitleOffsetX : 0);
            if (elSubtitleOffsetY) elSubtitleOffsetY.value = String((typeof opts.subtitleOffsetY === "number") ? opts.subtitleOffsetY : 0);
            if (elBgMode) elBgMode.value = opts.bgMode || "gradient";
            if (elBgDir) elBgDir.value = opts.bgDir || "tlbr";
            if (elBgSolid) elBgSolid.value = opts.bgSolid || "#0d6efd";
            elBgA.value = opts.bgA || "#0d6efd";
            elBgB.value = opts.bgB || "#198754";
            elRadius.value = String((typeof opts.radius === "number") ? opts.radius : 34);
            elShadow.value = String((typeof opts.shadow === "number") ? opts.shadow : 26);
            elFrame.value = opts.frame || "none";
            if (!elFrame.value) elFrame.value = "none";
            if (elRotation) elRotation.value = String((typeof opts.rotation === "number") ? opts.rotation : 0);
            if (el3dEnabled) el3dEnabled.checked = !!opts.enable3d;
            if (elTiltX) elTiltX.value = String((typeof opts.tiltX === "number") ? opts.tiltX : 0);
            if (elTiltY) elTiltY.value = String((typeof opts.tiltY === "number") ? opts.tiltY : 0);
            if (elDepth) elDepth.value = String((typeof opts.depth === "number") ? opts.depth : 24);
            elFit.value = opts.fit || "contain";
            elDeviceScale.value = String((typeof opts.deviceScale === "number") ? opts.deviceScale : 100);
            elOffsetX.value = String((typeof opts.offsetX === "number") ? opts.offsetX : 0);
            elOffsetY.value = String((typeof opts.offsetY === "number") ? opts.offsetY : 0);
            updateCustomSizeVisibility();
            updateBackgroundVisibility();
            update3dControls();
        }

        function commitActiveFromUi() {
            var s = getActiveScreen();
            if (!s) return;
            s.opts = collectOptions();
            syncProjectJson();
        }

        function scheduleRender() {
            if (rafId) cancelAnimationFrame(rafId);
            rafId = requestAnimationFrame(function () {
                rafId = 0;
                renderPreview();
            });
        }

        function renderPreview() {
            var s = getActiveScreen();
            if (!s) return;
            var item = s.image;
            var opts = Object.assign({}, s.opts || collectOptions());

            // Fit preview to both width + height so the full screen is visible without scrolling.
            var maxPreviewW = 560;
            var maxPreviewH = 560;
            var scale = Math.min(1, maxPreviewW / opts.outW, maxPreviewH / opts.outH);
            var pw = Math.max(260, Math.round(opts.outW * scale));
            var ph = Math.max(260, Math.round(opts.outH * scale));

            previewCanvas.width = pw;
            previewCanvas.height = ph;

            previewCtx.save();
            previewCtx.scale(scale, scale);
            renderTo(previewCtx, opts.outW, opts.outH, item.img, opts);
            previewCtx.restore();
            lastPreviewScale = scale;

            var threeMsg = "";
            if (opts.enable3d) {
                threeMsg = FEATURE_3D
                    ? (__last3dInfo && __last3dInfo.ok
                        ? " • 3D: ON"
                        : (" • 3D: FAILED (" + ((__last3dInfo && __last3dInfo.reason) ? __last3dInfo.reason : "unknown") + ")"))
                    : " • 3D: DISABLED";
            }

            elStatus.textContent = "Active: " + (s && s.name ? s.name : (item.name || ("Screenshot " + (activeIndex + 1)))) +
                " • Output: " + opts.outW + "×" + opts.outH +
                " • Frame: " + (opts.frame || "none") +
                " • Fit: " + (opts.fit || "contain") +
                " • Pos: (" + (typeof opts.offsetX === "number" ? opts.offsetX : 0) + "%, " + (typeof opts.offsetY === "number" ? opts.offsetY : 0) + "%)" +
                threeMsg +
                " • Preview scale: " + Math.round(scale * 100) + "% • Screens: " + project.screens.length;

            var platform = (elPlatform && elPlatform.value) ? elPlatform.value : (project.platform || "android");
            if (platform === "ios") {
                var hintIos = iosHint(opts);
                elPlayHints.textContent = hintIos.text;
            } else {
                var hint = googlePlayHint(opts, project.screens.length, (elPlayType && elPlayType.value) ? elPlayType.value : (project.playType || "app"));
                elPlayHints.textContent = hint.text;
            }
        }

        function exportPng(scale, filenameBase) {
            commitActiveFromUi();
            var s = getActiveScreen();
            if (!s) return;
            var item = s.image;
            var opts = Object.assign({}, s.opts || collectOptions());
            opts.__renderScale = scale;

            var outW = opts.outW * scale;
            var outH = opts.outH * scale;
            var canvas = document.createElement("canvas");
            canvas.width = outW;
            canvas.height = outH;
            var ctx = canvas.getContext("2d");
            ctx.scale(scale, scale);
            renderTo(ctx, opts.outW, opts.outH, item.img, opts);

            canvas.toBlob(function (blob) {
                if (!blob) return;
                var url = URL.createObjectURL(blob);
                var a = document.createElement("a");
                a.href = url;
                var base = filenameBase + "-" + opts.outW + "x" + opts.outH + (scale === 2 ? "@@2x" : "");
                a.download = base + ".png";
                document.body.appendChild(a);
                a.click();
                a.remove();
                setTimeout(function () { URL.revokeObjectURL(url); }, 3000);
            }, "image/png");
        }

        function makeSamplePngBlob() {
            return new Promise(function (resolve) {
                var w = 1170, h = 2532;
                var c = document.createElement("canvas");
                c.width = w; c.height = h;
                var ctx = c.getContext("2d");
                var g = ctx.createLinearGradient(0, 0, w, h);
                g.addColorStop(0, "#121826");
                g.addColorStop(1, "#3b82f6");
                ctx.fillStyle = g;
                ctx.fillRect(0, 0, w, h);
                ctx.fillStyle = "rgba(255,255,255,0.95)";
                ctx.font = "800 120px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif";
                ctx.fillText("DailyTools", 90, 140);
                ctx.font = "600 52px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif";
                ctx.fillStyle = "rgba(255,255,255,0.88)";
                ctx.fillText("Sample screenshot", 90, 300);
                ctx.fillStyle = "rgba(255,255,255,0.20)";
                ctx.fillRect(90, 420, w - 180, h - 600);
                c.toBlob(function (blob) {
                    blob.name = "sample.png";
                    resolve(blob);
                }, "image/png");
            });
        }

        function setActive(i) {
            activeIndex = i;
            var s = getActiveScreen();
            if (s && s.opts) applyOptionsToUi(s.opts);
            refreshActiveMarkers();
            updateButtons();
            syncProjectJson();
            scheduleRender();
        }

        function defaultOptsForNewScreen() {
            var o = collectOptions();
            // New screen should start blank so users can type per-screen copy.
            o.title = "";
            o.subtitle = "";
            o.offsetX = 0;
            o.offsetY = 0;
            o.font = "system";
            o.deviceScale = 100;
            o.rotation = 0;
            o.bgMode = "gradient";
            o.bgDir = "tlbr";
            o.bgSolid = "#0d6efd";
            o.titleColor = "#ffffff";
            o.subtitleColor = "#e6f0ff";
            o.titleScale = 100;
            o.subtitleScale = 100;
            o.titleOffsetX = 0;
            o.titleOffsetY = 0;
            o.subtitleOffsetX = 0;
            o.subtitleOffsetY = 0;
            o.enable3d = false;
            o.tiltX = 0;
            o.tiltY = 0;
            o.depth = 24;
            return o;
        }

        function makeId() {
            return "scr_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 8);
        }

        function addScreenFromImage(imageObj) {
            project.screens.push({
                id: makeId(),
                name: imageObj.name || ("Screenshot " + (project.screens.length + 1)),
                image: imageObj,
                opts: defaultOptsForNewScreen()
            });
        }

        function rebuildThumbRow() {
            elThumbRow.innerHTML = "";
            project.screens.forEach(function (s, idx) {
                var d = document.createElement("div");
                d.className = "asg-thumb" + (idx === activeIndex ? " active" : "");
                d.setAttribute("data-asg-idx", String(idx));
                var im = document.createElement("img");
                im.alt = s.name || ("Screenshot " + (idx + 1));
                im.src = s.image.url;
                d.appendChild(im);
                d.addEventListener("click", function () { setActive(idx); });
                elThumbRow.appendChild(d);
            });
        }

        function rebuildAllLists() {
            rebuildThumbRow();
            refreshActiveMarkers();
        }

        function handleUiChanged() {
            update3dControls();
            if (el3dEnabled && el3dEnabled.checked && (!window.THREE || typeof window.THREE.WebGLRenderer !== "function")) {
                ensureThreeLoaded().then(function () { scheduleRender(); });
            }
            commitActiveFromUi();
            refreshActiveMarkers();
            updateButtons();
            scheduleRender();
        }

        function applyPlatformUi(platform) {
            if (!platform) platform = "android";
            if (elPlayTypeRow) elPlayTypeRow.style.display = (platform === "android") ? "" : "none";
            rebuildFrameSelect(platform);
        }

        elPreset.addEventListener("change", function () {
            updateCustomSizeVisibility();
            var dims = getPresetDims(elPreset.value);
            if (dims && elPreset.value !== "custom") {
                elW.value = String(dims.w);
                elH.value = String(dims.h);
            }
            handleUiChanged();
        });

        elPlatform.addEventListener("change", function () {
            var platform = elPlatform.value || "android";
            project.platform = platform;
            applyPlatformUi(platform);
            rebuildPresetSelect(platform);
            updateCustomSizeVisibility();

            var dims = getPresetDims(elPreset.value);
            if (dims && elPreset.value !== "custom") {
                elW.value = String(dims.w);
                elH.value = String(dims.h);
            }

            handleUiChanged();
        });

        elPlayType.addEventListener("change", function () {
            syncProjectJson();
            scheduleRender();
        });

        [
            elW, elH,
            elTitle, elSubtitle,
            elFont,
            elTitleColor, elSubtitleColor,
            elTitleScale, elSubtitleScale,
            elTitleOffsetX, elTitleOffsetY,
            elSubtitleOffsetX, elSubtitleOffsetY,
            elBgMode, elBgDir, elBgSolid, elBgA, elBgB,
            elRadius, elShadow, elFrame, elRotation, elFit,
            el3dEnabled, elTiltX, elTiltY, elDepth,
            elDeviceScale, elOffsetX, elOffsetY
        ].forEach(function (el) {
            if (!el) return;
            el.addEventListener("input", handleUiChanged);
            el.addEventListener("change", handleUiChanged);
        });

        if (elBgMode) {
            elBgMode.addEventListener("change", function () {
                updateBackgroundVisibility();
            });
        }

        function setTitleOffsets(x, y) {
            if (elTitleOffsetX) elTitleOffsetX.value = String(clamp(x, -TEXT_PAN_MAX, TEXT_PAN_MAX));
            if (elTitleOffsetY) elTitleOffsetY.value = String(clamp(y, -TEXT_PAN_MAX, TEXT_PAN_MAX));
            handleUiChanged();
        }

        function setSubtitleOffsets(x, y) {
            if (elSubtitleOffsetX) elSubtitleOffsetX.value = String(clamp(x, -TEXT_PAN_MAX, TEXT_PAN_MAX));
            if (elSubtitleOffsetY) elSubtitleOffsetY.value = String(clamp(y, -TEXT_PAN_MAX, TEXT_PAN_MAX));
            handleUiChanged();
        }

        if (elTitleCenter) elTitleCenter.addEventListener("click", function () { setTitleOffsets(0, 0); });
        if (elSubtitleCenter) elSubtitleCenter.addEventListener("click", function () { setSubtitleOffsets(0, 0); });

        function setOffsets(x, y) {
            elOffsetX.value = String(clamp(x, -PAN_MAX, PAN_MAX));
            elOffsetY.value = String(clamp(y, -PAN_MAX, PAN_MAX));
            handleUiChanged();
        }

        elPosCenter.addEventListener("click", function () { setOffsets(0, 0); });
        elPosTop.addEventListener("click", function () { setOffsets(readFloat(elOffsetX, 0), -PAN_MAX); });
        elPosBottom.addEventListener("click", function () { setOffsets(readFloat(elOffsetX, 0), PAN_MAX); });
        elPosLeft.addEventListener("click", function () { setOffsets(-PAN_MAX, readFloat(elOffsetY, 0)); });
        elPosRight.addEventListener("click", function () { setOffsets(PAN_MAX, readFloat(elOffsetY, 0)); });

        // Drag to move (updates the same offsets used for export).
        // Normal drag = device/screenshot. Shift = Title. Alt+Shift = Subtitle.
        var drag = { active: false, lastX: 0, lastY: 0, mode: "device" };
        previewCanvas.addEventListener("pointerdown", function (e) {
            if (!getActiveScreen()) return;
            drag.active = true;
            drag.mode = (e.shiftKey && e.altKey) ? "subtitle" : (e.shiftKey ? "title" : "device");
            drag.lastX = e.clientX;
            drag.lastY = e.clientY;
            try { previewCanvas.setPointerCapture(e.pointerId); } catch (err) { }
        });
        previewCanvas.addEventListener("pointermove", function (e) {
            if (!drag.active) return;
            var s = getActiveScreen();
            if (!s || !s.opts) return;

            var rect = previewCanvas.getBoundingClientRect();
            var pxRatioX = rect.width > 0 ? (previewCanvas.width / rect.width) : 1;
            var pxRatioY = rect.height > 0 ? (previewCanvas.height / rect.height) : 1;

            var dxCanvas = (e.clientX - drag.lastX) * pxRatioX;
            var dyCanvas = (e.clientY - drag.lastY) * pxRatioY;
            drag.lastX = e.clientX;
            drag.lastY = e.clientY;

            var dxOut = dxCanvas / (lastPreviewScale || 1);
            var dyOut = dyCanvas / (lastPreviewScale || 1);

            if (drag.mode === "title" || drag.mode === "subtitle") {
                var oxKey = (drag.mode === "title") ? "titleOffsetX" : "subtitleOffsetX";
                var oyKey = (drag.mode === "title") ? "titleOffsetY" : "subtitleOffsetY";

                var tx = (typeof s.opts[oxKey] === "number") ? s.opts[oxKey] : 0;
                var ty = (typeof s.opts[oyKey] === "number") ? s.opts[oyKey] : 0;

                // Convert drag delta to percent of output size.
                tx += (dxOut / (s.opts.outW || 1)) * 100;
                ty += (dyOut / (s.opts.outH || 1)) * 100;

                tx = clamp(tx, -TEXT_PAN_MAX, TEXT_PAN_MAX);
                ty = clamp(ty, -TEXT_PAN_MAX, TEXT_PAN_MAX);

                s.opts[oxKey] = tx;
                s.opts[oyKey] = ty;

                if (drag.mode === "title") {
                    if (elTitleOffsetX) elTitleOffsetX.value = String(Math.round(tx));
                    if (elTitleOffsetY) elTitleOffsetY.value = String(Math.round(ty));
                } else {
                    if (elSubtitleOffsetX) elSubtitleOffsetX.value = String(Math.round(tx));
                    if (elSubtitleOffsetY) elSubtitleOffsetY.value = String(Math.round(ty));
                }

                scheduleRender();
                return;
            }

            var box = computeScreenBox(s.opts.outW, s.opts.outH, s.image.img, s.opts);
            var screenW = box.screenW || s.opts.outW;
            var screenH = box.screenH || s.opts.outH;
            var contentW = box.contentW || s.opts.outW;
            var contentH = box.contentH || s.opts.outH;
            var frameKind = box.frameKind || getFrameBaseKind(s.opts.frame || "none");

            var ox = (typeof s.opts.offsetX === "number") ? s.opts.offsetX : 0;
            var oy = (typeof s.opts.offsetY === "number") ? s.opts.offsetY : 0;

            // Convert drag delta to percent.
            // If a frame is used, we move the device (use content box as reference).
            // Otherwise we pan the screenshot (use screen box).
            if (frameKind !== "none") {
                ox += (dxOut / contentW) * 100;
                oy += (dyOut / contentH) * 100;
            } else {
                ox += (dxOut / screenW) * 100;
                oy += (dyOut / screenH) * 100;
            }

            ox = clamp(ox, -PAN_MAX, PAN_MAX);
            oy = clamp(oy, -PAN_MAX, PAN_MAX);

            s.opts.offsetX = ox;
            s.opts.offsetY = oy;
            elOffsetX.value = String(Math.round(ox));
            elOffsetY.value = String(Math.round(oy));

            scheduleRender();
        });
        function endDrag() {
            if (!drag.active) return;
            drag.active = false;
            syncProjectJson();
            refreshActiveMarkers();
            updateButtons();
        }
        previewCanvas.addEventListener("pointerup", endDrag);
        previewCanvas.addEventListener("pointercancel", endDrag);

        elFiles.addEventListener("change", function () {
            var files = Array.prototype.slice.call(elFiles.files || []);
            if (!files.length) return;

            Promise.all(files.map(addImageFromBlob)).then(function (loaded) {
                loaded.forEach(function (it) { addScreenFromImage(it); });
                if (activeIndex < 0) activeIndex = 0;
                rebuildAllLists();
                setActive(activeIndex);
            }).catch(function (e) {
                elStatus.textContent = "Failed to load one or more images. " + (e && e.message ? e.message : "");
            });
        });

        elUseSample.addEventListener("click", function () {
            makeSamplePngBlob().then(addImageFromBlob).then(function (it) {
                clearAll();
                addScreenFromImage(it);
                activeIndex = 0;
                rebuildAllLists();
                setActive(0);
            });
        });

        elClear.addEventListener("click", function () { clearAll(); });

        if (elApplyAll) {
            elApplyAll.addEventListener("click", function () {
                commitActiveFromUi();
                var src = getActiveScreen();
                if (!src || !src.opts) return;

                var shared = Object.assign({}, src.opts);
                project.screens.forEach(function (s, idx) {
                    if (!s || idx === activeIndex) return;
                    s.opts = Object.assign({}, shared);
                });

                syncProjectJson();
                refreshActiveMarkers();
                updateButtons();
                scheduleRender();

                if (window.DailyTools && typeof window.DailyTools.flashButtonText === "function") {
                    window.DailyTools.flashButtonText(elApplyAll, "Applied", 1200);
                }
            });
        }

        elDownloadLow.addEventListener("click", function () { exportPng(1, "app-screenshot"); });
        elDownloadHigh.addEventListener("click", function () { exportPng(2, "app-screenshot"); });

        elCopyProjectJson.addEventListener("click", function () {
            syncProjectJson();
            var json = window.__asgProjectJson || exportProjectJson();
            if (window.DailyTools && typeof window.DailyTools.copyToClipboard === "function") {
                window.DailyTools.copyToClipboard(json);
                if (window.DailyTools.flashButtonText) window.DailyTools.flashButtonText(elCopyProjectJson, "Copied", 1200);
                return;
            }
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(json);
            }
        });

        // initial
        // Initialize platform + presets before any screen is added.
        elPlatform.value = project.platform || "android";
        applyPlatformUi(elPlatform.value);
        rebuildPresetSelect(elPlatform.value);
        updateCustomSizeVisibility();
        updateBackgroundVisibility();

        var dimsInit = getPresetDims(elPreset.value);
        if (dimsInit && elPreset.value !== "custom") {
            elW.value = String(dimsInit.w);
            elH.value = String(dimsInit.h);
        }

        updateButtons();
        syncProjectJson();
    })();
</script>

