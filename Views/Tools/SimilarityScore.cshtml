@{
    // Titles + meta are set in ToolsController
}

<style>
    .similarity-page h1 { display: none; }
</style>

<div class="mx-auto" style="max-width: 1100px;">
    <h1 class="mb-2">Text similarity checker (percentage)</h1>
    <p class="text-muted mb-3">
        Get a similarity percentage between two texts. Adjust normalization options for more accurate comparison of content vs exact strings.
    </p>

    @await Html.PartialAsync("_TextSimilarityWidget", "Text similarity")

    <hr class="my-4" />

    <h2 class="h5">Use cases</h2>
    <p class="text-muted">
        Useful for spotting near-duplicates, lightly edited copies, repeated content, or “same meaning with small edits” comparisons.
        For exact differences, use <a href="/text-compare">Text compare</a>.
    </p>

    <h2 class="h5 mt-4">FAQs</h2>
    <div class="d-grid gap-2">
        <details>
            <summary class="fw-semibold">How is the similarity calculated?</summary>
            <div class="text-muted mt-2">
                The score blends word overlap (cosine similarity), word shingles (phrase overlap), and character n-grams (small edit robustness).
            </div>
        </details>
        <details>
            <summary class="fw-semibold">What should I set for word shingle and char gram?</summary>
            <div class="text-muted mt-2">
                Start with w-3 and c-5. Increase shingle size to be stricter on phrase matching; increase char grams to be stricter on formatting-level overlap.
            </div>
        </details>
        <details>
            <summary class="fw-semibold">Working with JSON payloads?</summary>
            <div class="text-muted mt-2">Try the <a href="/json-viewer">JSON viewer</a> to format and validate first.</div>
        </details>
    </div>
</div>

