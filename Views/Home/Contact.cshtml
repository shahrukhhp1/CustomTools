@{
    ViewData["Title"] = "Contact";
}

<div class="mx-auto" style="max-width: 920px;">
    <h1 class="mb-3">@ViewData["Title"]</h1>

    <p class="lead">
        Feedback and bug reports are welcome.
    </p>

    <p class="mb-2">
        Email:
        <a href="mailto:contact@gamezpanel.com">contact@gamezpanel.com</a>
    </p>

    <p class="mb-0 text-muted">
        Please avoid sending secrets. If you’re reporting a bug, include the tool name and a minimal repro input.
    </p>
</div>
